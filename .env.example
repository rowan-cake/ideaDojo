# Leave the key blank to use the built-in ambient idea responses.
# The key stays on the local server and is never sent to the browser.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Create a Web application OAuth client in Google Cloud, then add the client ID here.
# No Google client secret is needed for this identity-only GIS flow.
GOOGLE_CLIENT_ID=

# Keep false for local HTTP. Production HTTPS deployments should set this to true.
AUTH_COOKIE_SECURE=false
PORT=8787
